    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
